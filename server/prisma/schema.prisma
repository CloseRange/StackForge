generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SFCardPriority {
  COMMON
  UNCOMMON
  RARE
  LEGENDARY
}

enum SFCardDifficulty {
  EASY
  MEDIUM
  HARD
  EPIC
}

model SFUser {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  displayName      String
  avatarUrl        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdProjects  Project[] @relation("ProjectOwner")
  assignedCards    Card[]    @relation("CardAssignee")
}

model SFProject {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  cards       Card[]
}

model SFCard {
  id           String         @id @default(uuid())
  title        String
  description  String?
  priority     CardPriority
  difficulty   SFCardDifficulty
  xpValue      Int
  assigneeId   String?
  boardSlot    Int?
  deckId       String
  projectId    String
  tags         String[]       @default([])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignee     User?          @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  deck         Deck           @relation(fields: [deckId], references: [id], onDelete: Restrict)
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklist    ChecklistItem[]
}

model ChecklistItem {
  id        String   @id @default(uuid())
  cardId     String
  label      String
  completed  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}
